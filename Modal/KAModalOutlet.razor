@using Microsoft.AspNetCore.Components.Sections

@foreach (KAModalReference modalReference in Modals.Reverse())
{
    <SectionOutlet SectionName="@modalReference.SectionName" />

    @if (modalReference.IsDynamicComponent)
    {
        <CascadingValue TValue="KAModalReference" Value="modalReference">
            <KAModal @ref="modalReference.ModalRef">
                <DynamicComponent Type="@modalReference.ComponentType" Parameters="@modalReference.ComponentParameters" />
            </KAModal>
        </CascadingValue>
    }
}

