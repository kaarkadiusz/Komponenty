@inherits KAInputBase<string>

<KAInputBaseTemplate Label="@Label"
                     HelperText="@HelperText"
                     AdornmentPosition="@AdornmentPosition"
                     AdornmentIcon="@AdornmentIcon"
                     AdornmentText="@AdornmentText"
                     Variant="@Variant"
                     FocusInputTask="FocusAsync"
                     HtmlId="@IdAttribute"
                     ValidationResult="RecentValidationResult">
    <input @ref="ElementReference"
           @attributes="AdditionalAttributes"
           type="text"
           id="@IdAttribute"
           maxlength="@MaxLength"
           disabled="@Disabled"
           readonly="@ReadOnly"
           @bind-value:get="Value"
           @bind-value:set="InvokeValueChanged"
           @bind-value:event="@BoundEvent" />
</KAInputBaseTemplate>

